NODE_ENV=development
PORT=3000

# 数据库
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USER=newuser
DATABASE_PASS=newpassword!!
DATABASE_NAME=mfg_platform_test

# Redis（暂不配置，系统自动降级为内存LRU + 数据库轮询）
# REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=mfg-platform-dev-secret-2026
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# 文件存储（本地模式）
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./data/files

# 文件上传限制
FILE_MAX_SIZE_MB=50

# 日志配置
# LOG_TARGET: db（写数据库）| file（写文件）| both（同时写）
LOG_TARGET=db

# 限流配置（测试环境禁用）
THROTTLE_DISABLE=1
# 文件日志目录（LOG_TARGET=file 或 both 时生效）
LOG_FILE_DIR=./logs
